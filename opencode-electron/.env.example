# OpenCode Desktop Environment Configuration

# Security: Encryption key for electron-store (REQUIRED in production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENCODE_ENCRYPTION_KEY=your-secure-random-key-minimum-32-characters-long

# API Configuration
OPENCODE_API_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# Test-only login bypass (do NOT enable in production)
VITE_ALLOW_TEST_LOGIN_BYPASS=false

# Environment
NODE_ENV=development

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info