# OpenCode PoC Environment Template
# Copy to .env and fill in actual values

# Deployment Environment (development | production)
ENVIRONMENT=production

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production

# Server Configuration
OPENCODE__SERVER__HOST=0.0.0.0
OPENCODE__SERVER__PORT=8080

# Database Configuration
OPENCODE__DATABASE__PATH=/data/poc.db
OPENCODE__DATABASE__AUTO_INIT=true
OPENCODE__DATABASE__MAX_CONNECTIONS=20

# Upload Configuration
OPENCODE__UPLOAD__DIRECTORY=/data/uploads
OPENCODE__UPLOAD__MAX_FILE_SIZE_MB=50

# Redis Configuration (Wave 4+)
REDIS_URL=redis://:your-redis-password@127.0.0.1:6379
REDIS_PASSWORD=your-redis-password

# Logging
RUST_LOG=info

# AWS/S3 Configuration (Wave 3+)
AWS_ACCESS_KEY=your-aws-access-key-here
AWS_SECRET_KEY=your-aws-secret-key-here
# OR for MinIO development
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minioadmin
