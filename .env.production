# Production Environment Variables
# These should be set in the actual production environment, not committed to git

# JWT Secret (256-bit recommended)
JWT_SECRET=your-256-bit-secret-key-generated-with-openssl-rand-base64-32

# Database
DATABASE_URL=sqlite:/data/opencode.db

# Logging
RUST_LOG=info,actix_web=info

# Environment
ENVIRONMENT=production

# File Upload
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=104857600

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=8
