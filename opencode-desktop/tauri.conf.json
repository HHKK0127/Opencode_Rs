{
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "OpenCode",
  "version": "0.1.0",
  "identifier": "com.opencode.desktop",
  "windows": [
    {
      "title": "OpenCode",
      "width": 1200,
      "height": 800,
      "resizable": true,
      "fullscreen": false
    }
  ]
}
