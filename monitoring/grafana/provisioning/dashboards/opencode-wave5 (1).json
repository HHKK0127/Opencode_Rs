{
  "title": "OpenCode Wave 5 — Production Dashboard",
  "uid": "opencode-wave5",
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job='opencode-api'}[1m]))",
          "legendFormat": "stable"
        },
        {
          "expr": "sum(rate(http_requests_total{job='opencode-canary'}[1m]))",
          "legendFormat": "canary"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job='opencode-api',status=~'5..'}[5m]) / rate(http_requests_total{job='opencode-api'}[5m])",
          "legendFormat": "stable 5xx rate"
        },
        {
          "expr": "rate(http_requests_total{job='opencode-canary',status=~'5..'}[5m]) / rate(http_requests_total{job='opencode-canary'}[5m])",
          "legendFormat": "canary 5xx rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='opencode-api'}[5m]))",
          "legendFormat": "stable p95"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='opencode-canary'}[5m]))",
          "legendFormat": "canary p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Service Health (Readiness)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "READY", "color": "green" }, "0": { "text": "NOT READY", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job='opencode-api'}",
          "legendFormat": "stable"
        }
      ]
    },
    {
      "id": 5,
      "title": "Canary Health",
      "type": "stat",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "READY", "color": "green" }, "0": { "text": "NOT READY", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job='opencode-canary'}",
          "legendFormat": "canary"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(redis_cache_hits_total[10m]) / (rate(redis_cache_hits_total[10m]) + rate(redis_cache_misses_total[10m]) + 0.001)",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 7,
      "title": "Redis Operations/s",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(redis_operations_total[1m])",
          "legendFormat": "{{ operation }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight{job='opencode-api'})",
          "legendFormat": "stable in-flight"
        },
        {
          "expr": "sum(http_requests_in_flight{job='opencode-canary'})",
          "legendFormat": "canary in-flight"
        }
      ]
    },
    {
      "id": 9,
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job='opencode-api'}",
          "legendFormat": "stable RSS"
        },
        {
          "expr": "process_resident_memory_bytes{job='opencode-canary'}",
          "legendFormat": "canary RSS"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["opencode", "wave5", "canary"]
}
