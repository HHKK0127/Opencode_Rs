# === 必須環境変数 ===
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long!!!
DATABASE_URL=postgresql://user:password@localhost:5432/opencode

# === 推奨環境変数 ===
JWT_EXPIRATION_HOURS=24
ENVIRONMENT=development

# DB接続プール
OPENCODE__DATABASE__MAX_CONNECTIONS=50
OPENCODE__DATABASE__MIN_CONNECTIONS=5
OPENCODE__DATABASE__ACQUIRE_TIMEOUT_SECS=5

# Argon2（OWASP推奨）
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Redis
REDIS_URL=redis://127.0.0.1:6379

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=opencode-uploads

# テストユーザー（開発環境のみ）
TEST_USER_PASSWORD=ChangeMeInProduction123!

# ログレベル
RUST_LOG=info

# サーバー設定
OPENCODE__SERVER__HOST=127.0.0.1
OPENCODE__SERVER__PORT=8080
OPENCODE__SERVER__WORKERS=4
